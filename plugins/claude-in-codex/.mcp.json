{
  "mcpServers": {
    "claude-in-codex": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/briandconnelly/claude-in-codex.git@v0.6.0",
        "claude-in-codex-mcp"
      ],
      "env_vars": [
        "ANTHROPIC_API_KEY",
        "CLAUDE_IN_CODEX_ACCESS",
        "CLAUDE_IN_CODEX_CLAUDE_CONFIG",
        "CLAUDE_IN_CODEX_EFFORT",
        "CLAUDE_IN_CODEX_GIT_TIMEOUT_SECONDS",
        "CLAUDE_IN_CODEX_JOB_MAX_COUNT",
        "CLAUDE_IN_CODEX_JOB_MAX_SECONDS",
        "CLAUDE_IN_CODEX_JOB_TTL",
        "CLAUDE_IN_CODEX_MAX_BUDGET_USD",
        "CLAUDE_IN_CODEX_MAX_INPUT_BYTES",
        "CLAUDE_IN_CODEX_MODEL",
        "CLAUDE_IN_CODEX_STATE_DIR",
        "CLAUDE_IN_CODEX_SUPPORTED_MAJORS",
        "CLAUDE_IN_CODEX_TIMEOUT_SECONDS"
      ]
    }
  }
}
