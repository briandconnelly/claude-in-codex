{
  "mcpServers": {
    "cc-plugin-codex": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/briandconnelly/cc-plugin-codex.git@v0.4.0",
        "cc-plugin-codex-mcp"
      ],
      "env_vars": [
        "ANTHROPIC_API_KEY",
        "CC_PLUGIN_CODEX_ACCESS",
        "CC_PLUGIN_CODEX_CLAUDE_CONFIG",
        "CC_PLUGIN_CODEX_EFFORT",
        "CC_PLUGIN_CODEX_GIT_TIMEOUT_SECONDS",
        "CC_PLUGIN_CODEX_JOB_MAX_COUNT",
        "CC_PLUGIN_CODEX_JOB_MAX_SECONDS",
        "CC_PLUGIN_CODEX_JOB_TTL",
        "CC_PLUGIN_CODEX_MAX_BUDGET_USD",
        "CC_PLUGIN_CODEX_MAX_INPUT_BYTES",
        "CC_PLUGIN_CODEX_MODEL",
        "CC_PLUGIN_CODEX_STATE_DIR",
        "CC_PLUGIN_CODEX_SUPPORTED_MAJORS",
        "CC_PLUGIN_CODEX_TIMEOUT_SECONDS"
      ]
    }
  }
}
